{
  "name": "art-inspiration-agent",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "tsx server.ts",
    "build": "esbuild server.ts --bundle --platform=node --target=node20 --format=esm --packages=external --outfile=server.bundle.js",
    "build:index": "tsx src/scripts/build-index.ts",
    "start": "node server.bundle.js"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "esbuild": "^0.24.2",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "fast-glob": "^3.3.3",
    "helmet": "^8.1.0",
    "mammoth": "^1.9.1",
    "pdf-parse": "^1.1.1",
    "tsx": "^4.19.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.14",
    "@types/pdf-parse": "^1.1.5",
    "typescript": "^5.7.3"
  }
}
